# Backend
DATABASE_URL=          # PostgreSQL connection string
JWT_SECRET=            # Min 32 chars, random, e.g. openssl rand -hex 32
PORT=3001

# CORS
CORS_ORIGINS=          # Comma-separated allowed origins, e.g. https://yourdomain.com,https://admin.yourdomain.com

# Frontend
BACKEND_URL=           # Backend URL for Next.js rewrites

# Admin
# DATABASE_URL=        # Same as backend
ADMIN_JWT_SECRET=      # Min 32 chars, different from JWT_SECRET
