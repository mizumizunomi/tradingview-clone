// Admin app uses the same DB as the backend.
// This file must stay in sync with /backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  firstName String?
  lastName  String?
  plan      String   @default("none")
  avatar    String?
  bio       String?
  isBanned  Boolean  @default(false)
  banReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet        Wallet?
  subscription  UserSubscription?
  orders        Order[]
  positions     Position[]
  trades        Trade[]
  watchlist       WatchlistItem[]
  tradingSignals  TradingSignal[]
  botStrategies   BotStrategy[]
  botSettings     BotSettings?
  supportTickets  SupportTicket[]
  kyc             KycVerification?
  notifications   Notification[]

  @@map("users")
}

model UserSubscription {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier            PlanTier  @default(NONE)
  totalDeposited  Decimal   @default(0) @db.Decimal(20, 8)
  monthlyFee      Decimal   @default(0) @db.Decimal(20, 8)
  nextBillingDate DateTime?
  isActive        Boolean   @default(true)
  activatedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("user_subscriptions")
}

enum PlanTier {
  NONE
  DEFAULT
  SILVER
  GOLD
  PLATINUM
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance     Decimal  @default(0.00) @db.Decimal(20, 8)
  equity      Decimal  @default(0.00) @db.Decimal(20, 8)
  margin      Decimal  @default(0.00) @db.Decimal(20, 8)
  freeMargin  Decimal  @default(0.00) @db.Decimal(20, 8)
  marginLevel Decimal  @default(0.00) @db.Decimal(20, 8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id          String            @id @default(uuid())
  walletId    String
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId      String?
  type        TransactionType
  method      PaymentMethod     @default(WIRE_TRANSFER)
  amount      Decimal           @db.Decimal(20, 8)
  status      TransactionStatus @default(COMPLETED)
  description String?
  reference   String?
  note        String?
  completedAt DateTime?
  createdAt   DateTime          @default(now())

  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  ADMIN_ADJUSTMENT
  TRADE_FEE
  SUBSCRIPTION_FEE
}

enum PaymentMethod {
  WIRE_TRANSFER
  DEBIT_CARD
  CRYPTO
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model Asset {
  id           String        @id @default(uuid())
  symbol       String        @unique
  name         String
  category     AssetCategory
  broker       String
  baseAsset    String?
  quoteAsset   String?
  minOrderSize Decimal       @default(0.01)   @db.Decimal(20, 8)
  maxLeverage  Int           @default(100)
  spread       Decimal       @default(0.0001) @db.Decimal(20, 8)
  commission   Decimal       @default(0.0005) @db.Decimal(20, 8)
  apiSymbol    String?
  dataSource   DataSource
  isActive     Boolean       @default(true)
  isFeatured   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  orders    Order[]
  positions Position[]
  trades    Trade[]
  watchlist WatchlistItem[]

  @@map("assets")
}

enum AssetCategory {
  CRYPTO
  FOREX
  STOCKS
  FUTURES
  INDICES
  COMMODITIES
  FUNDS
  BONDS
  ECONOMY
  OPTIONS
}

enum DataSource {
  BINANCE
  YAHOO_FINANCE
  TWELVE_DATA
  MOCK
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId     String
  asset       Asset       @relation(fields: [assetId], references: [id])
  type        OrderType
  side        OrderSide
  quantity    Float
  leverage    Int         @default(1)
  entryPrice  Decimal?    @db.Decimal(20, 8)
  stopLoss    Decimal?    @db.Decimal(20, 8)
  takeProfit  Decimal?    @db.Decimal(20, 8)
  limitPrice  Decimal?    @db.Decimal(20, 8)
  status      OrderStatus @default(PENDING)
  filledAt    DateTime?
  filledPrice Decimal?    @db.Decimal(20, 8)
  margin      Decimal?    @db.Decimal(20, 8)
  commission  Decimal?    @db.Decimal(20, 8)
  spread      Decimal?    @db.Decimal(20, 8)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  position Position?

  @@map("orders")
}

enum OrderType {
  MARKET
  LIMIT
  STOP_LOSS
  TAKE_PROFIT
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  REJECTED
}

model Position {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset     @relation(fields: [assetId], references: [id])
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id])
  side          OrderSide
  quantity      Float
  leverage      Int
  entryPrice    Decimal   @db.Decimal(20, 8)
  currentPrice  Decimal   @db.Decimal(20, 8)
  stopLoss      Decimal?  @db.Decimal(20, 8)
  takeProfit    Decimal?  @db.Decimal(20, 8)
  unrealizedPnL Decimal   @default(0.00) @db.Decimal(20, 8)
  realizedPnL   Decimal   @default(0.00) @db.Decimal(20, 8)
  margin        Decimal   @db.Decimal(20, 8)
  commission    Decimal   @db.Decimal(20, 8)
  spread        Decimal   @db.Decimal(20, 8)
  swap          Decimal   @default(0.00) @db.Decimal(20, 8)
  isOpen        Boolean   @default(true)
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  updatedAt     DateTime  @updatedAt

  trades Trade[]

  @@map("positions")
}

model Trade {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id])
  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])
  type       TradeType
  side       OrderSide
  quantity   Float
  price      Decimal   @db.Decimal(20, 8)
  pnl        Decimal   @default(0.00) @db.Decimal(20, 8)
  commission Decimal   @db.Decimal(20, 8)
  executedAt DateTime  @default(now())

  @@map("trades")
}

enum TradeType {
  OPEN
  CLOSE
  PARTIAL_CLOSE
}

model WatchlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, assetId])
  @@map("watchlist")
}

model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  username  String    @unique
  password  String
  role      AdminRole @default(MANAGER)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  actions AdminAction[]

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  MANAGER
  SUPPORT
}

model AdminAction {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  action    String
  targetId  String
  details   Json
  createdAt DateTime @default(now())

  @@map("admin_actions")
}

// ========== AI TRADING BOT ==========
enum AssetClass {
  CRYPTO
  FOREX
  STOCK
  COMMODITY
}

enum SignalAction {
  BUY
  SELL
  HOLD
}

enum SignalStatus {
  PENDING
  EXECUTED
  EXPIRED
  CANCELLED
}

enum RiskLevel {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

model TradingSignal {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset           String
  assetClass      AssetClass
  action          SignalAction
  confidence      Decimal      @db.Decimal(10, 4)
  strategy        String
  reasoning       String
  technicalData   Json
  fundamentalData Json?
  entryPrice      Decimal?     @db.Decimal(20, 8)
  stopLoss        Decimal?     @db.Decimal(20, 8)
  takeProfit      Decimal?     @db.Decimal(20, 8)
  takeProfit2     Decimal?     @db.Decimal(20, 8)
  riskReward      Decimal?     @db.Decimal(10, 4)
  timeframe       String
  drawingData     Json?
  status          SignalStatus @default(PENDING)
  autoExecuted    Boolean      @default(false)
  createdAt       DateTime     @default(now())
  expiresAt       DateTime?

  @@map("trading_signals")
}

model BotStrategy {
  id               String     @id @default(uuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  assetClass       AssetClass
  indicators       Json
  rules            Json
  riskParams       Json
  isActive         Boolean    @default(true)
  backtestResults  Json?
  backtestDrawings Json?
  totalSignals     Int        @default(0)
  winRate          Decimal?   @db.Decimal(10, 4)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@map("bot_strategies")
}

model BotSettings {
  id                     String       @id @default(uuid())
  userId                 String       @unique
  user                   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoTradeEnabled       Boolean      @default(false)
  riskLevel              RiskLevel    @default(MODERATE)
  maxDailyTrades         Int          @default(10)
  maxDrawdownPercent     Decimal      @default(5.0)  @db.Decimal(10, 4)
  enabledAssetClasses    AssetClass[]
  notifyOnSignal         Boolean      @default(true)
  showBotDrawings        Boolean      @default(true)
  drawingColorScheme     String       @default("default")
  minConfidenceAutoTrade Decimal      @default(70.0) @db.Decimal(10, 4)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@map("bot_settings")
}

// ========== SUPPORT ==========
model SupportTicket {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  message     String
  status      SupportTicketStatus @default(OPEN)
  priority    SupportPriority     @default(NORMAL)
  adminNote   String?
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("support_tickets")
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ========== KYC ==========
model KycVerification {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        KycStatus @default(PENDING)
  fullName      String
  dateOfBirth   String
  country       String
  address       String
  documentType  String
  documentFront String
  documentBack  String?
  selfie        String?
  adminNote     String?
  assignedTo    String?
  submittedAt   DateTime  @default(now())
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("kyc_verifications")
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMIT
}

// ========== NOTIFICATIONS ==========
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

enum NotificationType {
  DEPOSIT_CONFIRMED
  DEPOSIT_REJECTED
  WITHDRAWAL_COMPLETED
  POSITION_CLOSED
  KYC_APPROVED
  KYC_REJECTED
  SUPPORT_REPLY
  SYSTEM
}
