# Database (required for Prisma). Railway provides DATABASE_URL.
DATABASE_URL=postgresql://user:password@localhost:5432/tradingview

# Twelve Data API key for real-time prices and candles. Get one at https://twelvedata.com
# If not set, the app falls back to mock data.
TWELVE_DATA_API_KEY=

# JWT secret for auth tokens. Use a long random string in production.
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Cloudinary — stores uploaded KYC documents. Get these from the Cloudinary dashboard.
# If unset, the KYC document-upload endpoint returns a "storage not configured" error.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Port (Railway sets PORT automatically)
PORT=3001
