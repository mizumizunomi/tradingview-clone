// Prisma Schema for TradingView Clone
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== USER & AUTHENTICATION ==========
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  password      String   // Hashed with bcrypt
  firstName     String?
  lastName      String?
  plan          String   @default("none")
  avatar        String?
  bio           String?
  isBanned      Boolean  @default(false)
  banReason     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wallet          Wallet?
  subscription    UserSubscription?
  orders          Order[]
  positions       Position[]
  trades          Trade[]
  watchlist       WatchlistItem[]
  tradingSignals  TradingSignal[]
  botStrategies   BotStrategy[]
  botSettings     BotSettings?

  @@map("users")
}

model UserSubscription {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier            PlanTier  @default(NONE)
  totalDeposited  Float     @default(0)
  monthlyFee      Float     @default(0)
  nextBillingDate DateTime?
  isActive        Boolean   @default(true)
  activatedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("user_subscriptions")
}

enum PlanTier {
  NONE
  DEFAULT
  SILVER
  GOLD
  PLATINUM
}

// ========== WALLET & BALANCE ==========
model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance       Float    @default(0.00)      // Starting balance $0 — must deposit
  equity        Float    @default(0.00)      // Balance + Unrealized P&L
  margin        Float    @default(0.00)      // Used margin
  freeMargin    Float    @default(0.00)      // Available for trading
  marginLevel   Float    @default(0.00)      // (Equity/Margin) * 100

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  Transaction[]

  @@map("wallets")
}

model Transaction {
  id            String   @id @default(uuid())
  walletId      String
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId        String?  // denormalized for faster queries

  type          TransactionType
  method        PaymentMethod    @default(WIRE_TRANSFER)
  amount        Float
  status        TransactionStatus @default(COMPLETED)
  description   String?
  reference     String?          // external reference / receipt ID
  note          String?
  completedAt   DateTime?

  createdAt     DateTime @default(now())

  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  ADMIN_ADJUSTMENT
  TRADE_FEE
  SUBSCRIPTION_FEE
}

enum PaymentMethod {
  WIRE_TRANSFER
  DEBIT_CARD
  CRYPTO
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

// ========== ASSETS & SYMBOLS ==========
model Asset {
  id            String   @id @default(uuid())
  symbol        String   @unique    // e.g., "BTCUSD", "XAUUSD", "AAPL"
  name          String              // e.g., "Bitcoin / U.S. dollar"
  category      AssetCategory
  broker        String              // e.g., "BINANCE", "PEPPERSTONE", "NYSE"
  baseAsset     String?             // e.g., "BTC"
  quoteAsset    String?             // e.g., "USD"
  
  // Trading parameters
  minOrderSize  Float    @default(0.01)
  maxLeverage   Int      @default(100)
  spread        Float    @default(0.0001)  // 1 pip = 0.0001
  commission    Float    @default(0.0005)  // 0.05%
  
  // For API mapping
  apiSymbol     String?             // Symbol format for external API
  dataSource    DataSource
  
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  orders        Order[]
  positions     Position[]
  trades        Trade[]
  watchlist     WatchlistItem[]
  
  @@map("assets")
}

enum AssetCategory {
  CRYPTO
  FOREX
  STOCKS
  FUTURES
  INDICES
  COMMODITIES
  FUNDS
  BONDS
  ECONOMY
  OPTIONS
}

enum DataSource {
  BINANCE
  YAHOO_FINANCE
  TWELVE_DATA
  MOCK
}

// ========== TRADING & ORDERS ==========
model Order {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  
  type          OrderType
  side          OrderSide
  quantity      Float
  leverage      Int      @default(1)
  
  // Prices
  entryPrice    Float?
  stopLoss      Float?
  takeProfit    Float?
  limitPrice    Float?
  
  // Status
  status        OrderStatus @default(PENDING)
  
  // Filled information
  filledAt      DateTime?
  filledPrice   Float?
  
  // Costs
  margin        Float?
  commission    Float?
  spread        Float?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  position      Position?
  
  @@map("orders")
}

enum OrderType {
  MARKET
  LIMIT
  STOP_LOSS
  TAKE_PROFIT
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  REJECTED
}

// ========== POSITIONS ==========
model Position {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id])
  
  side          OrderSide
  quantity      Float
  leverage      Int
  
  entryPrice    Float
  currentPrice  Float
  stopLoss      Float?
  takeProfit    Float?
  
  // Profit & Loss
  unrealizedPnL Float    @default(0.00)
  realizedPnL   Float    @default(0.00)
  
  // Costs
  margin        Float
  commission    Float
  spread        Float
  swap          Float    @default(0.00)  // Overnight/rollover fee
  
  isOpen        Boolean  @default(true)
  
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  
  updatedAt     DateTime @updatedAt
  
  trades        Trade[]
  
  @@map("positions")
}

// ========== TRADE HISTORY ==========
model Trade {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  positionId    String?
  position      Position? @relation(fields: [positionId], references: [id])
  
  type          TradeType
  side          OrderSide
  quantity      Float
  price         Float
  
  pnl           Float    @default(0.00)
  commission    Float
  
  executedAt    DateTime @default(now())
  
  @@map("trades")
}

enum TradeType {
  OPEN
  CLOSE
  PARTIAL_CLOSE
}

// ========== ADMIN ==========
model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  username  String    @unique
  password  String    // bcrypt hashed
  role      AdminRole @default(MANAGER)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  actions   AdminAction[]

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  MANAGER
  SUPPORT
}

model AdminAction {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  action    String   // e.g., "BALANCE_ADJUST", "BAN_USER", "CLOSE_POSITION", "EDIT_USER"
  targetId  String   // userId or positionId
  details   Json     // before/after values, reason, etc.
  createdAt DateTime @default(now())

  @@map("admin_actions")
}

// ========== AI TRADING BOT ==========
enum AssetClass {
  CRYPTO
  FOREX
  STOCK
  COMMODITY
}

enum SignalAction {
  BUY
  SELL
  HOLD
}

enum SignalStatus {
  PENDING
  EXECUTED
  EXPIRED
  CANCELLED
}

enum RiskLevel {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

model TradingSignal {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset           String
  assetClass      AssetClass
  action          SignalAction
  confidence      Float
  strategy        String
  reasoning       String
  technicalData   Json
  fundamentalData Json?
  entryPrice      Float?
  stopLoss        Float?
  takeProfit      Float?
  timeframe       String
  status          SignalStatus @default(PENDING)
  autoExecuted    Boolean      @default(false)
  createdAt       DateTime     @default(now())
  expiresAt       DateTime?

  @@map("trading_signals")
}

model BotStrategy {
  id              String     @id @default(uuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  assetClass      AssetClass
  indicators      Json
  rules           Json
  riskParams      Json
  isActive        Boolean    @default(true)
  backtestResults Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("bot_strategies")
}

model BotSettings {
  id                    String       @id @default(uuid())
  userId                String       @unique
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoTradeEnabled      Boolean      @default(false)
  riskLevel             RiskLevel    @default(MODERATE)
  maxDailyTrades        Int          @default(10)
  maxDrawdownPercent    Float        @default(5.0)
  enabledAssetClasses   AssetClass[]
  notifyOnSignal        Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@map("bot_settings")
}

// ========== WATCHLIST ==========
model WatchlistItem {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  order         Int      @default(0)
  
  createdAt     DateTime @default(now())
  
  @@unique([userId, assetId])
  @@map("watchlist")
}
